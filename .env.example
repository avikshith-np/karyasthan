# =============================================================================
# Easiest setup: run `npm run setup` — it creates this .env interactively,
# generates your bot's persona, runs migrations, and offers WhatsApp pairing.
# Or copy this file to .env and fill it in by hand.
#
# The persona (name, personality, language) is NOT configured here — it lives in
# src/personality/persona.json + identity.md, generated by `npm run setup`.
# =============================================================================

# LLM
LLM_PROVIDER=openrouter          # anthropic | openai | gemini | openrouter | ollama
LLM_MODEL=gemini-3-flash-preview
LLM_API_KEY=
OPENROUTER_API_KEY=             # OpenRouter API key (or set LLM_API_KEY if provider=openrouter)
GLM_API_KEY=                    # Zhipu AI GLM API key (only needed if LLM_PROVIDER=glm)
GEMINI_API_KEY=                 # Google Gemini API key (only needed if LLM_PROVIDER=gemini)
LLM_MONTHLY_BUDGET_USD=30
LLM_FALLBACK_PROVIDER=ollama
LLM_FALLBACK_MODEL=gemini-3-flash-preview
LLM_MAX_TOKENS=3072              # Max tokens per LLM response (high enough for reasoning models that burn tokens thinking before output)
LLM_TEMPERATURE=0.7              # LLM temperature (lower = more coherent)
TRANSCRIPTION_MODEL=gemini-3-flash-preview

# WhatsApp phone number (digits only, with country code, e.g. 919876543210)
WA_PHONE_NUMBER=

# Behavior
RESPONSE_RATE=0.15
MAX_RESPONSE_LENGTH=500
SLEEP_START_HOUR=0
SLEEP_END_HOUR=7
TIMEZONE=Asia/Kolkata

# Rate Limits
MAX_PER_GROUP_HOUR=8
MAX_GLOBAL_HOUR=20

# Paths
DB_PATH=./data/karyasthan.db
AUTH_PATH=./data/auth_info_baileys
LOG_LEVEL=info

# Warm-up
WARMUP_ENABLED=true

# Dry run (logs responses instead of sending)
DRY_RUN=false

# Bill Split (uses Gemini Pro for receipt OCR — only for bill splitting)
BILL_SPLIT_MODEL=gemini-2.5-pro

# Image Generation (uses GEMINI_API_KEY)
IMAGE_GEN_ENABLED=true
IMAGE_GEN_MODEL=imagen-4.0-generate-001
# Model used when editing a replied-to image (image-in → image-out)
IMAGE_EDIT_MODEL=gemini-3-pro-image-preview
IMAGE_GEN_MAX_PER_HOUR=5

# Voice Notes (uses GEMINI_API_KEY for Gemini TTS)
VOICE_NOTE_ENABLED=true
VOICE_NOTE_MODEL=gemini-3.1-flash-tts-preview
VOICE_NOTE_VOICE=Puck
VOICE_NOTE_MAX_PER_HOUR=10

# Quality Gate (uses cheap Gemini Flash to check response quality before sending)
QUALITY_GATE_ENABLED=true
QUALITY_GATE_PROVIDER=gemini
QUALITY_GATE_MODEL=gemini-3-flash-preview
QUALITY_GATE_THRESHOLD=0.4           # 0.0-1.0, below this = blocked
QUALITY_GATE_MENTION_THRESHOLD=0.25  # Lower threshold for @mentions
QUALITY_GATE_MAX_TOKENS=150
QUALITY_GATE_TIMEOUT_MS=3000

# Stickers + GIFs (key from https://developers.giphy.com/dashboard)
GIPHY_API_KEY=
STICKER_MAX_PER_HOUR=8
GIF_MAX_PER_HOUR=8

# Dashboard (web UI on localhost — expose via SSH tunnel or Tailscale)
DASHBOARD_ENABLED=false
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=7070
DASHBOARD_USER=
DASHBOARD_PASS_HASH=            # bcrypt hash: node -e 'import("bcryptjs").then(b=>b.default.hash("yourpass",10).then(console.log))'
DASHBOARD_COOKIE_SECRET=        # random 32+ char string (defaults to PASS_HASH if empty)
DASHBOARD_ALLOW_CIDRS=127.0.0.1/32,::1/128
DASHBOARD_READONLY=true         # hard kill-switch — v1 is read-only only
